# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key for backend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon key for frontend

# Market data
ALPHA_VANTAGE_KEY=YOUR_KEY
FINNHUB_KEY=YOUR_KEY

# Optional: Telegram (Phase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: auto-execute HIGH conviction signals (paper trades)
# Solo aplica al portfolio single-user (user_id NULL). Default: deshabilitado.
AUTO_EXECUTE_HIGH=false
AUTO_EXECUTE_MAX_PER_DAY=3
