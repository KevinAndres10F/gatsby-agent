# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key for backend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon key for frontend

# Market data
ALPHA_VANTAGE_KEY=YOUR_KEY
FINNHUB_KEY=YOUR_KEY

# Notificaciones · Telegram (canal por defecto / fallback single-user)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notificaciones · proximidad a stop/target (% para disparar el aviso)
STOP_PROXIMITY_PCT=1.5

# Risk Manager (segunda opinión). Default: Opus 4.8. Para abaratar:
# RISK_REVIEW_MODEL=claude-sonnet-4-6
RISK_REVIEW_MODEL=

# Optional: auto-execute HIGH conviction signals (paper trades)
# Solo aplica al portfolio single-user (user_id NULL). Default: deshabilitado.
# Ahora exige además que la señal pase el Risk Manager (risk_approved).
AUTO_EXECUTE_HIGH=false
AUTO_EXECUTE_MAX_PER_DAY=3
